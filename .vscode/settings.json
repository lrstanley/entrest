{
  "files.associations": {
    "**/*.gotmpl": "go-template",
  },
  "files.exclude": {
    "**/*.example": true,
    "**/*.log": true,
    "**/*.sum": true,
    "**/.*ignore": true,
    "**/.golangci.yml": true,
    "**/LICENSE": true,
    "**/tmp": true,
    "**/.astro": true,
  },
  "go.lintTool": "golangci-lint-v2",
  "go.lintFlags": [
    "--fix"
  ],
  "gopls": {
    "formatting.gofumpt": true
  },
  "[mdx]": {
    "editor.defaultFormatter": "unifiedjs.vscode-mdx"
  }
}
